# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOUPEDB_MASTER_KEY=replace_with_64_char_hex_string

# Optional: protect the whole LoupeDB instance with a password (empty = disabled)
LOUPEDB_APP_PASSWORD=

# Optional tuning (defaults shown)
LOUPEDB_MAX_SESSIONS=20
LOUPEDB_IDLE_TIMEOUT_MS=1800000
